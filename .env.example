# App database (Docker Compose defaults: user postgres, password postgres, DB cardekho).
# If something else already uses 5432, run: CARDEKHO_PG_PORT=5433 docker compose up -d
# and point URLs at localhost:5433 instead.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cardekho?schema=public"

# Vitest defaults to cardekho_test with the same host/port/credentials (see vitest.test-db-url.ts).
# VITEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cardekho_test?schema=public"

# Playwright webServer defaults to cardekho_e2e (see playwright.config.ts).
# E2E_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cardekho_e2e?schema=public"

# Render / managed Postgres: use the dashboard connection string; append ?sslmode=require when SSL is required.

# mock = no external LLM (default for review). groq = real Groq API.
AI_PROVIDER=mock

# Only needed when AI_PROVIDER=groq
GROQ_API_KEY=
# Example model id (not a secret):
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — only if you implement signed cookies / JWT sessions. The default anonymous
# session uses an opaque UUID + DB row and does NOT read SESSION_SECRET.
# SESSION_SECRET=
