# SQLite (local) — use Postgres on Render with ?sslmode=require
DATABASE_URL="file:./dev.db"

# mock = no external LLM (default for review). groq = real Groq API.
AI_PROVIDER=mock

# Only needed when AI_PROVIDER=groq
GROQ_API_KEY=
# Example model id (not a secret):
GROQ_MODEL=llama-3.3-70b-versatile
